   "source": [
    "prices = [100,250,400,1200,50]\n",
    "price_with_gst = list(map(lambda price : price + price * 18/100,prices))\n",
    "\n",
    "print(f'Price list  with gst : {price_with_gst}')\n",
    "print(f'Price list without gst : {prices}')"
   ]
  }
