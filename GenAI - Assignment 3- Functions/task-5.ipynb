   "source": [
    "prices = [100,250,400,1200,50,2000,850]\n",
    "expensive_product = list(filter(lambda price : price > 500 ,prices))\n",
    "cheap_product = list(filter(lambda price : price <= 500 ,prices))\n",
    "print(expensive_product)\n",
    "print(cheap_product)"
   ]
  }
